generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FailedEventStatus {
  FAILED,
  REPLAY_PENDING,
  REPLAYED,
  REPLAY_FAILED
}

enum ReplayLogStatus {
  SUCCESS,
  FAILED,
  REQUESTED,
  SKIPPED_ALREADY_PROCESSED
}

model Order {
  id               String   @id @default(cuid())
  orderNumber      String   @unique
  tenantId         String
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("INR")
  status           String   @default("CREATED")
  inventoryStatus  String   @default("PENDING")
  paymentStatus    String   @default("PENDING")
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@map("orders")
}

model FailedEvent {
  id                 String            @id @default(cuid())
  eventId            String            @unique
  eventType          String
  tenantId           String
  streamName         String
  orderId            String?
  originalPayload    Json
  errorMessage       String
  retryCount         Int               @default(0)
  status             FailedEventStatus @default(FAILED)
  firstFailedAt      DateTime
  lastFailedAt       DateTime
  replayedAt         DateTime?
  replayRequestedBy  String?
  replayMetadata     Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  replayLogs         ReplayLog[]

  @@index([status])
  @@index([tenantId])
  @@index([orderId])
  @@index([eventType])
  @@map("failed_events")
}